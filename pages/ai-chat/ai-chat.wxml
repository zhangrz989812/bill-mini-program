<!--pages/ai-chat/ai-chat.wxml-->
<view class="page">
  <scroll-view class="message-list" scroll-y="true" scroll-into-view="{{scrollToMessage}}">
    <view wx:if="{{messages.length === 0}}" class="empty">
      <view class="empty-icon">🤖</view>
      <view class="empty-title">AI账单助手</view>
      <view class="empty-desc">可以问我本月消费、分类支出、大额支出和省钱建议。</view>
    </view>

    <view
      wx:for="{{messages}}"
      wx:key="index"
      id="msg-{{index}}"
      class="message {{item.role === 'user' ? 'message-user' : 'message-assistant'}}"
    >
      <view class="bubble">
        {{item.content}}
      </view>
    </view>

    <view wx:if="{{loading}}" class="message message-assistant">
      <view class="bubble loading-bubble">
        <text class="loading-dot">●</text>
        <text class="loading-dot">●</text>
        <text class="loading-dot">●</text>
      </view>
    </view>
  </scroll-view>

  <view class="quick-list" wx:if="{{messages.length === 0}}">
    <view
      wx:for="{{quickQuestions}}"
      wx:key="index"
      class="quick-item"
      data-question="{{item}}"
      bindtap="onQuickQuestion"
    >
      {{item}}
    </view>
  </view>

  <view class="input-bar">
    <input
      class="input"
      value="{{inputValue}}"
      placeholder="问问你的账单情况"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" bindtap="sendMessage" disabled="{{loading}}">
      发送
    </button>
  </view>
</view>
