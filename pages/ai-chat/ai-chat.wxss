/* pages/ai-chat/ai-chat.wxss */
.page {
  min-height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
}

.message-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty {
  margin-top: 120rpx;
  text-align: center;
  color: #666;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #888;
  padding: 0 48rpx;
  line-height: 1.6;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
}

.message-user {
  justify-content: flex-end;
}

.message-assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

.message-user .bubble {
  background: #0052d9;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.message-assistant .bubble {
  background: #fff;
  color: #222;
  border-bottom-left-radius: 6rpx;
}

.loading-bubble {
  display: flex;
  gap: 8rpx;
}

.loading-dot {
  animation: loading 1.4s infinite both;
  font-size: 24rpx;
  color: #888;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes loading {
  0%, 80%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  40% {
    opacity: 1;
    transform: scale(1);
  }
}

.quick-list {
  display: flex;
  overflow-x: auto;
  padding: 16rpx 24rpx;
  background: #f5f7fa;
  white-space: nowrap;
}

.quick-list::-webkit-scrollbar {
  display: none;
}

.quick-item {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #0052d9;
  border: 1rpx solid #0052d9;
}

.quick-item:active {
  background: #e6f0ff;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: #0052d9;
  color: #fff;
  font-size: 28rpx;
  padding: 0;
}

.send-btn[disabled] {
  background: #a0c4ff;
  color: #fff;
}
