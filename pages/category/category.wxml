<!--pages/category/category.wxml-->
<view class="container">
  <!-- 类型切换 -->
  <view class="type-switch">
    <view class="switch-btn {{categoryType === 'expense' ? 'active' : ''}}" 
          data-type="expense" bindtap="switchType">
      支出分类
    </view>
    <view class="switch-btn {{categoryType === 'income' ? 'active' : ''}}" 
          data-type="income" bindtap="switchType">
      收入分类
    </view>
  </view>

  <!-- 编辑按钮 -->
  <view class="edit-section">
    <view class="edit-btn" bindtap="{{isEditing ? 'stopEditing' : 'startEditing'}}">
      {{isEditing ? '完成编辑' : '编辑分类'}}
    </view>
  </view>

  <!-- 分类列表 -->
  <view class="category-list">
    <view class="category-item" wx:for="{{categories}}" wx:key="id">
      <view class="category-info">
        <view class="category-icon" style="background-color: {{item.color}}">
          {{item.icon}}
        </view>
        <view class="category-details">
          <text class="category-name">{{item.name}}</text>
          <text class="category-count">已记录 {{item.count}} 笔</text>
        </view>
      </view>
      
      <view class="category-actions" wx:if="{{isEditing}}">
        <view class="action-btn edit-btn" data-id="{{item.id}}" bindtap="editCategory">
          编辑
        </view>
        <view class="action-btn delete-btn" data-id="{{item.id}}" bindtap="deleteCategory"
              wx:if="{{!item.isDefault}}">
          删除
        </view>
      </view>
      
      <view class="default-tag" wx:if="{{item.isDefault && !isEditing}}">
        默认
      </view>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-section" wx:if="{{!isEditing}}">
    <button class="add-btn" bindtap="showAddModal">+ 新增分类</button>
  </view>

  <!-- 新增弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">新增分类</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      
      <view class="modal-body">
        <!-- 分类名称 -->
        <view class="form-group">
          <text class="form-label">分类名称</text>
          <input placeholder="请输入分类名称" value="{{newCategory.name}}" 
                 bindinput="inputCategoryName" class="form-input"/>
        </view>
        
        <!-- 选择图标 -->
        <view class="form-group">
          <text class="form-label">选择图标</text>
          <view class="icon-list">
            <view class="icon-item {{newCategory.icon === item ? 'selected' : ''}}" 
                  wx:for="{{presetIcons}}" wx:key="*this" 
                  data-icon="{{item}}" bindtap="selectIcon">
              {{item}}
            </view>
          </view>
        </view>
        
        <!-- 选择颜色 -->
        <view class="form-group">
          <text class="form-label">选择颜色</text>
          <view class="color-list">
            <view class="color-item {{newCategory.color === item ? 'selected' : ''}}" 
                  wx:for="{{presetColors}}" wx:key="*this" 
                  style="background-color: {{item}}" data-color="{{item}}" bindtap="selectColor">
            </view>
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="cancel-btn" bindtap="hideModal">取消</button>
        <button class="confirm-btn" bindtap="addCategory">确认添加</button>
      </view>
    </view>
  </view>
</view>