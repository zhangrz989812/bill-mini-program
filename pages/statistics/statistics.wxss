/* pages/statistics/statistics.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 时间选择器 */
.time-selector {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.range-btn {
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
  transition: all 0.3s;
}

.range-btn.active {
  background-color: #0052d9;
  color: #fff;
  font-weight: bold;
}

.date-picker {
  margin-left: auto;
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.date-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 10rpx;
}

.date-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 概览卡片 */
.overview-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.overview-value {
  font-size: 32rpx;
  font-weight: bold;
}

.overview-value.income {
  color: #07c160;
}

.overview-value.expense {
  color: #fa5151;
}

.overview-value.balance {
  color: #0052d9;
}

.overview-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #eee;
}

/* 图表区域 */
.chart-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #0052d9;
}

.chart-placeholder {
  height: 400rpx;
  position: relative;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
  padding-bottom: 50rpx;
}

.chart-bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
}

.chart-bar {
  width: 20rpx;
  border-radius: 4rpx 4rpx 0 0;
  margin-bottom: 10rpx;
}

.income-bar {
  background-color: #07c160;
}

.expense-bar {
  background-color: #fa5151;
}

.chart-date {
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}

.chart-legend {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.legend-color.income {
  background-color: #07c160;
}

.legend-color.expense {
  background-color: #fa5151;
}

/* 分类统计 */
.category-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-list {
  margin-top: 20rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.category-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.category-details {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.category-amount {
  font-size: 26rpx;
  color: #666;
}

.category-progress {
  display: flex;
  align-items: center;
  width: 200rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  margin-right: 15rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.5s;
}

.percentage {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #ddd;
  border-top: 4rpx solid #0052d9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}